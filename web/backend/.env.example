# === App ===
APP_NAME=Laguitos Web
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# JWT expiration in minutes (default: 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Database ===
# Dev (SQLite): sqlite+aiosqlite:///./data/laguitos.db
# Prod (PostgreSQL): postgresql+asyncpg://user:pass@host:5432/laguitos
DATABASE_URL=sqlite+aiosqlite:///./data/laguitos.db

# === Data directory (downloads, temp files) ===
DATA_DIR=./data

# === Seed Users (optional — only needed on first run) ===
# Remove from .env.prod after first deploy to avoid password overwrites
SEED_USER_1_EMAIL=moises@laguitos.app
SEED_USER_1_PASSWORD=changeme
SEED_USER_1_NAME=Moisés
SEED_USER_2_EMAIL=estefany@laguitos.app
SEED_USER_2_PASSWORD=changeme
SEED_USER_2_NAME=Estefany

# === File Cleanup ===
FILE_TTL_HOURS=48
CLEANUP_INTERVAL_SECONDS=3600
