# ═══════════════════════════════════════════════════════════════
#  Laguitos Web — .env.example
# ═══════════════════════════════════════════════════════════════
#  Template de configuración para dev local con Docker.
#  `scripts/docker/init.ps1` lo copia a `.env` en la raíz del
#  repo si aún no existe.
#
#  IMPORTANTE: tras copiarlo, editá los valores marcados como
#  CHANGE_ME_* antes del primer `docker compose up`.
# ═══════════════════════════════════════════════════════════════


# ─── App ─────────────────────────────────────────────────────
APP_NAME=Laguitos Web
DEBUG=true

# Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_AT_LEAST_32_CHARS_LONG

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# ─── Base de datos ───────────────────────────────────────────
# En dev: SQLite con aiosqlite (path absoluto dentro del container).
# Docker compose lo sobrescribe con /app/data/laguitos.db, pero
# lo dejamos acá para ejecuciones nativas (sin Docker).
DATABASE_URL=sqlite+aiosqlite:///./data/laguitos.db


# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500","http://localhost:8080","http://localhost:8000"]


# ─── Paths ───────────────────────────────────────────────────
# En Docker lo sobrescribe compose a /app/data. En host nativo
# queda relativo al CWD.
DATA_DIR=./data


# ─── Usuarios seed ───────────────────────────────────────────
# Solo se crean si NO existen aún en la BD (idempotente).
# Cambiá las passwords antes del primer arranque real.
SEED_USER_1_EMAIL=moises@laguitos.app
SEED_USER_1_PASSWORD=CHANGE_ME_MOISES_PASSWORD
SEED_USER_1_NAME=Moisés

SEED_USER_2_EMAIL=estefany@laguitos.app
SEED_USER_2_PASSWORD=CHANGE_ME_ESTEFANY_PASSWORD
SEED_USER_2_NAME=Estefany


# ─── Limpieza automática de archivos descargados ─────────────
# TTL tras el cual los .mp4/.mp3 completados se borran del disk
# (el registro en BD se conserva pero marcado con file_path=NULL).
FILE_TTL_HOURS=48
CLEANUP_INTERVAL_SECONDS=3600
